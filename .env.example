# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string — any provider with pgvector works.
# Supabase: Settings → Database → Connection String (Transaction mode)
# Neon: Dashboard → Connection Details
# Railway: Your project → PostgreSQL → Connect
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Embedding Model ──────────────────────────────────────────────────────────
# Any OpenAI-compatible /v1/embeddings endpoint.
# Switching providers? Re-run `npm run ingest` to re-embed your knowledge base.
#
# OpenAI:   https://api.openai.com/v1          model: text-embedding-3-small
# Voyage:   https://api.voyageai.com/v1        model: voyage-3-lite
# Jina:     https://api.jina.ai/v1             model: jina-embeddings-v3
# Ollama:   http://localhost:11434/v1          model: nomic-embed-text
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-...

# Dimensions MUST match your chosen model. Update schema.sql if you change this.
# text-embedding-3-small → 1536  |  voyage-3-lite → 512  |  nomic-embed-text → 768
EMBEDDING_DIMENSIONS=1536

# ─── Chat Model ───────────────────────────────────────────────────────────────
# Any OpenAI-compatible /v1/chat/completions endpoint.
#
# OpenAI:      https://api.openai.com/v1           model: gpt-4o-mini
# OpenRouter:  https://openrouter.ai/api/v1        model: google/gemini-2.5-flash
# Ollama:      http://localhost:11434/v1           model: llama3.2
# Groq:        https://api.groq.com/openai/v1      model: llama-3.1-8b-instant
CHAT_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=google/gemini-2.5-flash
CHAT_API_KEY=sk-or-...

# ─── RAG Settings ─────────────────────────────────────────────────────────────
# Cosine similarity threshold — chunks below this score are ignored.
MATCH_THRESHOLD=0.7
# Maximum number of knowledge base chunks to include in each prompt.
MATCH_COUNT=5
